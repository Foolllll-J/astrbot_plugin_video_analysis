{
    "session_whitelist": {
        "description": "会话白名单",
        "hint": "留空表示所有会话都可解析。群聊填写群号，私聊填写用户 ID。",
        "type": "list",
        "default": []
    },
    "platform_parse": {
        "type": "object",
        "description": "平台解析配置",
        "hint": "管理各平台的解析行为与登录凭据。",
        "items": {
            "platform_whitelist": {
                "description": "启用的解析平台",
                "hint": "选择需要启用解析的平台。未选择的平台链接将自动跳过。全部不选则插件完全不处理。",
                "type": "list",
                "options": [
                    "bilibili",
                    "douyin",
                    "xiaohongshu",
                    "tieba",
                    "nga"
                ],
                "labels": [
                    "Bilibili",
                    "抖音",
                    "小红书",
                    "贴吧",
                    "NGA"
                ],
                "default": [
                    "bilibili",
                    "douyin",
                    "xiaohongshu",
                    "tieba",
                    "nga"
                ]
            },
            "enable_emoji_reaction": {
                "description": "解析时贴表情",
                "hint": "开启后，将在开始解析、解析成功、解析失败时对原消息进行表情回应。",
                "type": "bool",
                "default": true
            },
            "smart_downgrade": {
                "description": "清晰度智能降级",
                "hint": "开启后，长视频将自动降级清晰度，以避免超出视频大小限制。",
                "type": "bool",
                "default": true
            },
            "bilibili": {
                "type": "object",
                "description": "B站解析配置",
                "hint": "配置 B站 视频下载清晰度与登录策略。",
                "items": {
                    "use_login": {
                        "description": "使用登录状态下载",
                        "hint": "启用后将尝试使用登录状态下载高清视频。发送 /bili_login 进行扫码登录。禁用则强制使用无登录方式。",
                        "type": "bool",
                        "default": false
                    },
                    "quality": {
                        "description": "视频清晰度",
                        "hint": "选择 B站 视频下载清晰度。若未启用登录，最高仅支持 360P。",
                        "type": "int",
                        "default": 64,
                        "options": [
                            16,
                            32,
                            64,
                            80,
                            112,
                            120
                        ],
                        "labels": [
                            "360P",
                            "480P",
                            "720P",
                            "1080P",
                            "1080P+",
                            "4K"
                        ]
                    }
                }
            },
            "douyin": {
                "type": "object",
                "description": "抖音解析配置",
                "hint": "配置抖音解析凭据。",
                "items": {
                    "cookie": {
                        "description": "抖音 Cookie",
                        "hint": "选填，用于本地解析抖音视频。",
                        "type": "string",
                        "default": null
                    },
                    "api_url": {
                        "description": "抖音解析 API 地址",
                        "hint": "选填。作为所有本地解析方案都失败后的兜底方案。",
                        "type": "string",
                        "default": ""
                    }
                }
            },
            "xhs": {
                "type": "object",
                "description": "小红书解析配置",
                "hint": "配置小红书解析的凭据与图片质量。",
                "items": {
                    "cookie": {
                        "description": "小红书 Cookie",
                        "hint": "选填，仅用于访问需要登录的笔记。",
                        "type": "string",
                        "default": ""
                    },
                    "image_quality": {
                        "description": "小红书图片质量",
                        "hint": "自动压缩使用 CDN 压缩版，体积小但会附带水印。",
                        "type": "string",
                        "options": [
                            "original",
                            "auto"
                        ],
                        "labels": [
                            "原始画质",
                            "自动压缩"
                        ],
                        "default": "original"
                    }
                }
            },
            "tieba_sort": {
                "description": "贴吧回帖排序方式",
                "hint": "回帖排序方式：提供按时间正序和按点赞数降序两种方式。",
                "type": "string",
                "options": [
                    "time",
                    "hot"
                ],
                "labels": [
                    "按时间排序",
                    "按热度排序"
                ],
                "default": "time"
            },
            "nga": {
                "type": "object",
                "description": "NGA 解析配置",
                "hint": "配置 NGA 论坛帖子解析的凭据与排序。",
                "items": {
                    "cookie": {
                        "description": "NGA Cookie",
                        "hint": "建议填写。登录 bbs.nga.cn 后，复制完整 Cookie 填入。用于访问需要登录的帖子。",
                        "type": "string"
                    },
                    "sort": {
                        "description": "NGA 回帖排序方式",
                        "hint": "回帖排序方式：提供按时间正序和按点赞数降序两种方式。",
                        "type": "string",
                        "options": [
                            "time",
                            "hot"
                        ],
                        "labels": [
                            "按时间排序",
                            "按热度排序"
                        ],
                        "default": "time"
                    }
                }
            }
        }
    },
    "delivery": {
        "type": "object",
        "description": "投递配置",
        "hint": "控制媒体文件的下载大小上限、清理时间、图片数量及长文转发行为。",
        "items": {
            "max_video_size": {
                "description": "最大视频大小（MB）",
                "hint": "视频文件的最大允许大小，超过此限制将无法发送。",
                "type": "int",
                "default": 200
            },
            "delete_time": {
                "description": "删除文件时间（分钟）",
                "hint": "视频文件保存的时间，超过此时间将被自动删除。",
                "type": "int",
                "default": 60
            },
            "text_forward_threshold": {
                "description": "正文转发阈值（有效字数）",
                "hint": "当标题或正文超过此字数时（不计空格、标点、话题标签），将使用合并转发同时发送文本和媒体内容。设为 0 表示不启用此功能。适用于抖音、小红书等平台。",
                "type": "int",
                "slider": {
                    "min": 0,
                    "max": 100,
                    "step": 1
                },
                "default": 50
            },
            "max_images": {
                "description": "图片解析上限",
                "hint": "设置图文作品解析的最大图片数量，超过此上限的图片将被忽略。适用于抖音与小红书。",
                "type": "int",
                "slider": {
                    "min": 1,
                    "max": 99,
                    "step": 1
                },
                "default": 20
            },
            "max_replies": {
                "description": "回帖解析上限",
                "hint": "设置贴吧、NGA 等论坛帖子的最大回帖数量，超过此上限的回帖将被忽略。",
                "type": "int",
                "slider": {
                    "min": 1,
                    "max": 99,
                    "step": 1
                },
                "default": 20
            }
        }
    },
    "parse_throttle": {
        "type": "object",
        "description": "解析限制配置",
        "hint": "仅对群聊普通成员生效；管理员与群主默认不受限。",
        "items": {
            "whitelist": {
                "description": "解析限制白名单",
                "hint": "填入用户或群组 ID，匹配的成员不受群等级与频率限制。留空表示无白名单。",
                "type": "list",
                "default": []
            },
            "admin_bypass_content_restrictions": {
                "description": "管理员是否跳过内容级限制",
                "hint": "开启后，管理员不受视频时长、发送大小、屏蔽词限制。",
                "type": "bool",
                "default": true
            },
            "min_group_level": {
                "description": "最低群等级限制",
                "hint": "仅在 QQ(aiocqhttp) 群聊中生效。普通成员群等级低于该值时不触发解析；设为 0 表示不限制。",
                "type": "int",
                "default": 0,
                "slider": {
                    "min": 0,
                    "max": 100,
                    "step": 1
                }
            },
            "blocked_keywords": {
                "description": "解析屏蔽关键词",
                "hint": "若视频标题中包含这些关键词，则不会触发解析。",
                "type": "list",
                "items": {
                    "type": "string"
                },
                "default": []
            },
            "max_duration": {
                "description": "最大视频时长（秒）",
                "hint": "超过此时长的视频将不进行解析下载。设为 0 表示不限制。",
                "type": "int",
                "default": 0
            },
            "window_sec": {
                "description": "统计窗口（秒）",
                "hint": "在该时间窗口内统计请求次数。设为 0 表示不启用限制。",
                "type": "int",
                "default": 0
            },
            "max_requests": {
                "description": "窗口内最大请求数",
                "hint": "同一群聊成员在统计窗口内允许的最大解析次数。",
                "type": "int",
                "default": 2
            },
            "cooldown_sec": {
                "description": "冷却时长（秒）",
                "hint": "触发超限后，在冷却时间内继续请求会被直接拦截。",
                "type": "int",
                "default": 60
            },
            "block_parallel": {
                "description": "拦截并发解析",
                "hint": "开启后，同一群聊成员上一条解析未完成前，新解析请求会被拦截。",
                "type": "bool",
                "default": true
            }
        }
    }
}
