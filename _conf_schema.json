{
    "nap_server_address": {
        "description": "Napcat 服务地址",
        "hint": "若与服务端在同一台机器上请保持默认。",
        "type": "string",
        "default": "localhost"
    },
    "nap_server_port": {
        "description": "Napcat 接收文件端口",
        "hint": "若与服务端在同一台机器上请保持默认。",
        "type": "int",
        "default": 3658
    },
    "session_whitelist": {
        "description": "会话白名单",
        "hint": "留空表示所有会话都可解析。群聊填写群号，私聊填写用户 ID。",
        "type": "list",
        "items": {
            "type": "string"
        },
        "default": []
    },
    "delete_time": {
        "description": "删除文件时间（分钟）",
        "hint": "视频文件保存的时间，超过此时间将被自动删除。",
        "type": "int",
        "default": 60
    },
    "max_video_size": {
        "description": "最大视频大小（MB）",
        "hint": "视频文件的最大允许大小，超过此限制将无法发送。",
        "type": "int",
        "default": 100
    },
    "enable_emoji_reaction": {
        "description": "解析时贴表情",
        "hint": "开启后，将在开始解析、解析成功、解析失败时对原消息进行表情回应。",
        "type": "bool",
        "default": true
    },
    "bilibili": {
        "type": "object",
        "description": "B站解析配置",
        "hint": "配置 B站 视频下载清晰度与登录策略。",
        "items": {
            "use_login": {
                "description": "使用登录状态下载",
                "hint": "启用后将尝试使用登录状态下载高清视频，禁用则强制使用无登录方式。",
                "type": "bool",
                "default": false
            },
            "quality": {
                "description": "视频清晰度",
                "hint": "16: 360P | 32: 480P | 64: 720P | 80: 1080P | 112: 1080P+ | 120: 4K",
                "type": "int",
                "default": 64,
                "options": [
                    16,
                    32,
                    64,
                    80,
                    112,
                    120
                ]
            },
            "smart_downgrade": {
                "description": "清晰度智能降级",
                "hint": "开启后，长视频将自动降级清晰度，以避免超出视频大小限制。",
                "type": "bool",
                "default": true
            }
        }
    },
    "douyin": {
        "type": "object",
        "description": "抖音解析配置",
        "hint": "配置抖音本地解析与 API 兜底策略。",
        "items": {
            "cookie": {
                "description": "抖音 Cookie",
                "hint": "选填，用于本地解析抖音视频。",
                "type": "string",
                "default": null
            },
            "api_url": {
                "description": "抖音解析 API 地址",
                "hint": "选填。若填写 Cookie 则作为本地解析失败后的兜底；若未填 Cookie 则作为唯一解析方案；若均未填则禁用抖音解析。",
                "type": "string",
                "default": ""
            },
            "max_images": {
                "description": "抖音图文作品解析上限",
                "hint": "设置抖音图文作品解析的最大图片数量，超过此上限的图片将被忽略。",
                "type": "int",
                "slider": {
                    "min": 1,
                    "max": 99,
                    "step": 1
                },
                "default": 20
            }
        }
    },
    "parse_throttle": {
        "type": "object",
        "description": "解析限制配置",
        "hint": "仅对群聊普通成员生效；管理员与群主默认不受限。",
        "items": {
            "min_group_level": {
                "description": "最低群等级限制",
                "hint": "仅在 QQ(aiocqhttp) 群聊中生效。普通成员群等级低于该值时不触发解析；设为 0 表示不限制。",
                "type": "int",
                "default": 0,
                "slider": {
                    "min": 0,
                    "max": 100,
                    "step": 1
                }
            },
            "blocked_keywords": {
                "description": "解析屏蔽关键词",
                "hint": "若消息文本或 JSON 卡片的标题/描述等关键信息中包含这些关键词，则不会触发解析。",
                "type": "list",
                "items": {
                    "type": "string"
                },
                "default": []
            },
            "window_sec": {
                "description": "统计窗口（秒）",
                "hint": "在该时间窗口内统计请求次数。设为 0 表示不启用限制。",
                "type": "int",
                "default": 0
            },
            "max_requests": {
                "description": "窗口内最大请求数",
                "hint": "同一群聊成员在统计窗口内允许的最大解析次数。",
                "type": "int",
                "default": 2
            },
            "cooldown_sec": {
                "description": "冷却时长（秒）",
                "hint": "触发超限后，在冷却时间内继续请求会被直接拦截。",
                "type": "int",
                "default": 60
            },
            "block_parallel": {
                "description": "拦截并发解析",
                "hint": "开启后，同一群聊成员上一条解析未完成前，新解析请求会被拦截。",
                "type": "bool",
                "default": true
            }
        }
    }
}
